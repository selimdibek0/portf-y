      "subtitle": {
        "tr": "Online Rezervasyon ve Filo Yönetim Sistemi",
        "en": "Online Reservation & Fleet Management System"
      },
      "problem": {
        "tr": "Küçük ölçekli kiralama firmaları araç müsaitliğini telefon veya defter üzerinden takip ediyordu; çakışan rezervasyonlar operasyonel verimsizlik yaratıyordu.",
        "en": "Small rental companies tracked vehicle availability by phone or notebook; overlapping reservations hurt operational efficiency."
      },
      "solution": {
        "tr": "Araç listeleme, tarih bazlı müsaitlik kontrolü, online rezervasyon ve admin paneli içeren full-stack bir uygulama geliştirdim.",
        "en": "Built a full-stack app with vehicle listing, date-based availability, online booking, and admin panel."
      },
      "result": {
        "tr": "Rezervasyon süreci tek platformda toplandı; müsaitlik kontrolü otomatikleşerek çakışma riski ortadan kalktı.",
        "en": "Reservation process unified on one platform; automatic availability checks eliminated conflicts."
      }
    },
